<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="StationName" value="BT 1" />
    <!-- ou DOWNLOADER 2 -->
  </appSettings>
  <system.webServer>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath=".\BTAutomation.exe" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
  </system.webServer>
</configuration>
